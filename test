const SCENARIOS = {
  scenario_1: { name: "Играть, чтобы выиграть", icon: "🏆", color: "#4ade80", desc: "Здоровый сценарий. Ты видишь цель и движешься к ней стратегически." },
  scenario_2: { name: "Играть, чтобы играть", icon: "🎨", color: "#60a5fa", desc: "Кайф от процесса важнее результата. Творчество и общение — твоя стихия." },
  scenario_3: { name: "Не выиграть", icon: "😰", color: "#a78bfa", desc: "Боишься последствий успеха больше, чем провала. Стартуешь, но не финишируешь." },
  scenario_4: { name: "Жопник", icon: "🆘", color: "#fb923c", desc: "Живёшь от кризиса к кризису. Мотивация включается только когда припирает." },
  scenario_5: { name: "Не играть, но хотеть", icon: "🎲", color: "#f472b6", desc: "Много идей и планов, но ответственность перекладывается на темп, обстоятельства или знания." },
  scenario_6: { name: "Не играть", icon: "🚫", color: "#f87171", desc: "Запрещаешь себе хотеть или считаешь что это не для тебя." },
  scenario_7: { name: "Проиграть", icon: "😢", color: "#94a3b8", desc: "Проигрыш в одном даёт выгоды в другом — поддержку, сочувствие, избегание ответственности." },
  scenario_8: { name: "Галочник", icon: "🎭", color: "#64748b", desc: "Формально участвуешь, делаешь минимум, ищешь причины не делать." },
};

// Dani context — pre-loaded awareness
const DANI_CONTEXT = {
  hasBusinesses: true,
  isStudent: true,
  focusNeeded: true
};

let current = 0;
let answers = []; // store selected opt index per question

function init() {
  renderQuestion(0);
}

function renderQuestion(idx) {
  const q = questions[idx];
  const screen = document.getElementById('quizScreen');
  const letters = ['А','Б','В','Г'];

  let blockLabel = '';
  if (idx === 0 || questions[idx].block !== questions[idx-1]?.block) {
    blockLabel = `<div class="section-label">${q.block}</div>`;
  }

  screen.innerHTML = `
    ${blockLabel}
    <div class="question-card">
      <div class="q-number">Вопрос ${idx+1} из ${questions.length}</div>
      <div class="q-text">${q.text}</div>
      ${q.sub ? `<div class="q-sub">${q.sub}</div>` : ''}
      <div class="options" id="opts">
        ${q.opts.map((o,i) => `
          <div class="opt ${answers[idx]===i?'selected':''}" onclick="selectOpt(${i})" data-i="${i}">
            <div class="opt-letter">${letters[i]}</div>
            <div class="opt-text">${o.text}</div>
          </div>
        `).join('')}
      </div>
    </div>
    <div class="nav">
      ${idx > 0 ? `<button class="btn btn-back" onclick="goBack()">← Назад</button>` : ''}
      <button class="btn btn-next" id="btnNext" onclick="goNext()" ${answers[idx]===undefined?'disabled':''}>
        ${idx < questions.length-1 ? 'Далее →' : 'Получить результат'}
      </button>
    </div>
  `;

  updateProgress(idx);
}

function selectOpt(i) {
  answers[current] = i;
  document.querySelectorAll('.opt').forEach((el,idx) => {
    el.classList.toggle('selected', idx===i);
  });
  document.getElementById('btnNext').disabled = false;
}

function goNext() {
  if (answers[current] === undefined) return;
  if (current < questions.length - 1) {
    current++;
    renderQuestion(current);
    window.scrollTo({top:0, behavior:'smooth'});
  } else {
    showResult();
  }
}

function goBack() {
  if (current > 0) {
    current--;
    renderQuestion(current);
    window.scrollTo({top:0, behavior:'smooth'});
  }
}

function updateProgress(idx) {
  const pct = Math.round((idx / questions.length) * 100);
  document.getElementById('progressFill').style.width = pct + '%';
  document.getElementById('progressLabel').textContent = `Вопрос ${idx+1} из ${questions.length}`;
  document.getElementById('progressPct').textContent = pct + '%';
}

function computeScores() {
  const scores = {};
  Object.keys(SCENARIOS).forEach(k => scores[k] = 0);

  answers.forEach((ansIdx, qIdx) => {
    const tags = questions[qIdx].opts[ansIdx].tags;
    tags.forEach(t => { scores[t] = (scores[t]||0) + 1; });
  });

  return scores;
}

function getTopScenarios(scores) {
  return Object.entries(scores)
    .sort((a,b) => b[1]-a[1])
    .filter(([,v]) => v > 0)
    .slice(0, 4);
}

function computeTraits(scores) {
  const total = questions.length;
  // derive trait scores from scenario weights
  return {
    "Стратегичность": Math.round((scores.scenario_1 / total) * 100),
    "Системность": Math.round(Math.max(0, (scores.scenario_1 * 1.2 - scores.scenario_4 * 0.5) / total * 100)),
    "Действие vs Подготовка": Math.round(Math.max(0, 100 - (scores.scenario_5 + scores.scenario_2) * 12)),
    "Устойчивость к страху": Math.round(Math.max(0, 100 - (scores.scenario_6 + scores.scenario_3) * 14)),
    "Фокус": Math.round(Math.max(0, 100 - (scores.scenario_5 + scores.scenario_8) * 12)),
  };
}

function getPrimaryScenario(top) {
  return top[0][0];
}

function getRecommendations(primary, scores) {
  const recs = {
    scenario_1: [
      "Выбери <strong>одно главное направление</strong> в бизнесе на следующие 1–4 месяца и не распыляйся.",
      "Составь 90-дневный план с конкретными измеримыми цифрами (клиенты, выручка).",
      "Делегируй задачи, которые не требуют тебя лично.",
      "Аудит окружения: убери источники, снижающие энергию ниже 7/10.",
    ],
    scenario_2: [
      "<strong>Поставь измеримую цель на 90 дней</strong> — не «делать качественные рилсы», а «20 клиентов» или «300к выручки».",
      "Ежедневно задавай себе вопрос: «Что я сделал СЕГОДНЯ, что приблизило меня к цели?»",
      "Раздели свою работу на «творческое» и «коммерческое» — второе должно занимать минимум 30% времени.",
      "Правило 72 часов: любая идея без первого действия за 72ч — удалить из списка.",
    ],
    scenario_3: [
      "Выпиши конкретно: <strong>чего именно ты боишься после победы?</strong> Это и есть настоящий барьер.",
      "Сделай один некомфортный шаг в ближайшие 24 часа — позвони клиенту, выложи рилс, назначь встречу.",
      "Перестань готовиться к запуску — начни запуск и готовься параллельно.",
      "Напомни себе: страх последствий успеха > страха провала. Это сценарий, а не факт.",
    ],
    scenario_4: [
      "<strong>Создай финансовую подушку</strong> — 10% с каждого поступления, без исключений.",
      "Планируй неделю в воскресенье — до того, как начались пожары.",
      "Поставь одну цель из желания, а не из страха — и работай только над ней.",
      "Заведи 'план минимум' на месяц чтобы не попадать в кризис каждый раз.",
    ],
    scenario_5: [
      "<strong>Выбери ONE нишу/продукт/направление</strong> и дай себе обещание не менять 90 дней.",
      "Правило 72 часов: идея не стала действием за 72ч — удаляешь.",
      "Сделай первое конкретное действие по текущей идее в течение 24 часов после прочтения этого.",
      "Разорви связь «готов» и «делаю» — ты никогда не будешь достаточно готов.",
    ],
    scenario_6: [
      "Признай честно: «не хочу» = «боюсь». Запиши что именно страшит.",
      "<strong>Напиши письмо от 60-летнего себя</strong>, который так и не попробовал — прочитай вслух.",
      "Сделай самый маленький и безопасный шаг: не запуск, а один разговор с человеком, который это уже делает.",
      "Разреши себе хотеть. Просто начни играть — не побеждать, а играть.",
    ],
    scenario_7: [
      "Выпиши все сферы где ты «проигрываешь» + кому выгоден твой проигрыш в каждой.",
      "Убери все выгоды от проигрыша — поддержку за счёт жалоб, избегание ответственности.",
      "Честный разговор с собой: что ты реально хочешь и почему молчишь об этом.",
    ],
    scenario_8: [
      "Задай себе вопрос: <strong>чем я сейчас занимаюсь просто потому что «надо»?</strong>",
      "Выбери одно и скажи вслух: «Я не хочу в это играть. Я выхожу из этой игры.»",
      "Начни делать то, что ты ДЕЙСТВИТЕЛЬНО хочешь — пусть даже маленький шаг.",
    ],
  };
  return recs[primary] || recs.scenario_1;
}

function getIllusions(scores) {
  const illusions = [];
  if (scores.scenario_5 >= 2 || scores.scenario_6 >= 1) illusions.push({ text: "Вот-вот", type: "warn" });
  if (scores.scenario_6 >= 2) illusions.push({ text: "Недостойного", type: "warn" });
  if (scores.scenario_3 >= 2 || scores.scenario_5 >= 3) illusions.push({ text: "Проклятого", type: "warn" });
  if (scores.scenario_6 >= 1 || scores.scenario_3 >= 1) illusions.push({ text: "Осуждения", type: "warn" });
  if (scores.scenario_2 >= 2) illusions.push({ text: "Миллионов", type: "info" });
  return illusions;
}

function getStrengths(scores) {
  const s = [];
  if (scores.scenario_1 >= 3) s.push({ text: "Стратегическое мышление", type: "ok" });
  if (scores.scenario_2 >= 2) s.push({ text: "Творческий подход", type: "ok" });
  if (scores.scenario_1 >= 2) s.push({ text: "Ориентация на результат", type: "ok" });
  if (scores.scenario_4 <= 1 && scores.scenario_1 >= 1) s.push({ text: "Управляемый стресс", type: "ok" });
  if (s.length === 0) s.push({ text: "Осознанность — ты уже видишь паттерны", type: "ok" });
  return s;
}

function showResult() {
  document.getElementById('progressWrap').classList.add('hidden');
  const scores = computeScores();
  const top = getTopScenarios(scores);
  const primary = getPrimaryScenario(top);
  const pScenario = SCENARIOS[primary];
  const traits = computeTraits(scores);
  const recs = getRecommendations(primary, scores);
  const illusions = getIllusions(scores);
  const strengths = getStrengths(scores);
  const total = questions.length;

  const scenarioRows = top.map(([key, val], i) => {
    const s = SCENARIOS[key];
    const pct = Math.round((val / (total * 0.7)) * 100);
    const capped = Math.min(pct, 100);
    return `
      <div class="scenario-row ${i===0?'primary':'secondary'}">
        <div class="s-name">${s.icon} ${s.name}</div>
        <div class="s-bar-wrap"><div class="s-bar ${i===0?'gold':'dim'}" style="width:0%" data-w="${capped}"></div></div>
        <div class="s-pct">${capped}%</div>
      </div>
    `;
  }).join('');

  const traitRows = Object.entries(traits).map(([label, val]) => `
    <div class="trait-row">
      <div class="trait-label">${label}</div>
      <div class="trait-bar-wrap"><div class="trait-bar" style="width:0%" data-w="${val}"></div></div>
      <div class="trait-value">${val}%</div>
    </div>
  `).join('');

  const actionItems = recs.map((r,i) => `
    <div class="action-item">
      <div class="action-num">${i+1}</div>
      <div class="action-text">${r}</div>
    </div>
  `).join('');

  const illusionPills = illusions.map(il => `<span class="pill ${il.type}">${il.text}</span>`).join('');
  const strengthPills = strengths.map(s => `<span class="pill ${s.type}">${s.text}</span>`).join('');

  const resultHtml = `
    <div class="result-hero">
      <div class="result-scenario-badge">Основной сценарий</div>
      <div class="result-icon">${pScenario.icon}</div>
      <div class="result-title">${pScenario.name}</div>
      <div class="result-desc">${pScenario.desc}</div>
    </div>

    <div class="block">
      <div class="block-title">Распределение сценариев</div>
      <div class="scenario-grid">${scenarioRows}</div>
    </div>

    <div class="block">
      <div class="block-title">Профиль характеристик</div>
      ${traitRows}
    </div>

    ${strengths.length ? `
    <div class="block">
      <div class="block-title">Сильные стороны</div>
      <div class="pills">${strengthPills}</div>
    </div>
    ` : ''}

    ${illusions.length ? `
    <div class="block">
      <div class="block-title">Активные иллюзии</div>
      <div class="pills">${illusionPills}</div>
      <div class="quote-block" style="margin-top:14px">
        Иллюзии разбиваются только переходом в реальность — конкретным первым действием в реальном мире.
      </div>
    </div>
    ` : ''}

    <div class="block">
      <div class="block-title">Твои первые шаги</div>
      <div class="action-list">${actionItems}</div>
    </div>

    <div class="block">
      <div class="block-title">Ключевое</div>
      <div class="quote-block">
        Пока ты в своём сценарии — ты будешь использовать любые инструменты так, чтобы в нём остаться. Осознание сценария — это уже первый шаг к его изменению.<br><br>
        За один период можно измениться только в чём-то <strong>одном</strong>. Выбери это одно прямо сейчас.
      </div>
    </div>

    <button class="btn-restart" onclick="restart()">↺ Пройти заново</button>
  `;

  document.getElementById('quizScreen').classList.add('hidden');
  const rs = document.getElementById('resultScreen');
  rs.innerHTML = resultHtml;
  rs.classList.add('visible');
  window.scrollTo({top:0, behavior:'smooth'});

  // Animate bars after render
  setTimeout(() => {
    document.querySelectorAll('.trait-bar[data-w], .s-bar[data-w]').forEach(el => {
      el.style.width = el.dataset.w + '%';
    });
  }, 100);
}

function restart() {
  current = 0;
  answers = [];
  document.getElementById('progressWrap').classList.remove('hidden');
  document.getElementById('resultScreen').classList.remove('visible');
  document.getElementById('resultScreen').innerHTML = '';
  document.getElementById('quizScreen').classList.remove('hidden');
  renderQuestion(0);
  window.scrollTo({top:0, behavior:'smooth'});
}

init();
</script>
